        "func": "if (msg.payload.destinations.includes('provideMDB')) {\n    switch (msg.payload.com) {\n        case \"init0\":\n            {// Заглужка - ответ БД со списками\n                let arr1 = [\n                    { ID: 1, DNS: \"\", ExpectName: \"PLC11\", Type: \"plc\", IP: \"192.168.50.151\", Port: \"8080\", ChExpected: 64 },\n                    { ID: 2, DNS: \"\", ExpectName: \"PLC21\", Type: \"plc\", IP: \"192.168.50.156\", Port: \"8080\", ChExpected: 64 },\n                    { ID: 3, DNS: \"\", ExpectName: \"PLC22\", Type: \"plc\", IP: \"192.168.50.157\", Port: \"8080\", ChExpected: 64 },\n                    { ID: 4, DNS: \"\", ExpectName: \"PLC31\", Type: \"plc\", IP: \"192.168.50.161\", Port: \"8080\", ChExpected: 64 },\n                    { ID: 5, DNS: \"\", ExpectName: \"PLC32\", Type: \"plc\", IP: \"192.168.50.162\", Port: \"8080\", ChExpected: 64 },\n                ];\n                let arr2 = [\n                    { ServiceName: \"Process\", Importance: \"Critical\"},\n                    { ServiceName: \"WSClient\", Importance: \"Critical\"},\n                    { ServiceName: \"Logger\", Importance: \"Critical\"},\n                    { ServiceName: \"DeviceManager\", Importance: \"Critical\"},\n                    { ServiceName: \"ProxyWSClient\", Importance: \"Critical\"},\n                ];\n\n                if (true) { // Заглушка - если соединение установилось\n                    msg = {'payload': 'ProviderMDB inited!'};\n                }\n                else {\n                    msg = {'payload': 'ProviderMDB failed!'};\n                }\n                node.send(msg);// ответ для дебага\n            }\n            break;\n        default:            \n    }\n}",

    {
        "id": "6ac3a41adf3f730c",
        "type": "function",
        "z": "55950d16b2398bc5",
        "g": "07f4702e7e5f5c11",
        "name": "serviceProcess",
        "func": "if (msg.payload.destinations.includes('process') ||\n    msg.payload.destinations.includes('broadcast')) {\n// Нода отвечает за работу сервиса Process - разворачивает все необходимые модули при деплое, \n// а также начало работы по команде пользователя\n    switch (msg.payload.com) {\n        case \"start\":\n            {   // Создание объекта Process\n                const ClassProcessSrv = global.get('ClassProcessSrv');\n                const Process = new ClassProcessSrv();\n                let {sysBus, logBus, mdbBus, dataBus} = Process.Init();\n                const GlobalBusList = {\n                    'sysBus': sysBus,\n                    'logBus': logBus,\n                    'mdbBus': mdbBus,\n                    'dataBus': dataBus\n                }\n                flow.set(\"GlobalBusList\", GlobalBusList);\n                msg = { topic: 'process-init0', payload: { timestamp: 123, hash: 'erijhgiorej', value: 0, source: 'process', com: 'init0', arg: [], destinations: ['provideMDB']}};\n                node.send(msg);\n                flow.set('process', Process);                \n            }\n            break;\n        case \"run\": {// Команда клиентам -> подключение к источникам \n                flow.get('process').Run();\n            }\n            break;\n        case \"debug\": {// Дебаг - выводполей процесса\n                const Process = flow.get('process');\n                msg = { topic: 'process-debug', payload: { timestamp: 123, hash: 'erijhgiorej', value: 0, source: 'process', com: 'resp', arg: [Process._SourcesState, Process._ServicesState], destinations: ['debug']}};\n                node.send(msg);// ответ для дебага\n            }\n            break;\n        default:            \n    }\n}\n// Создание Process",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 120,
        "wires": [
